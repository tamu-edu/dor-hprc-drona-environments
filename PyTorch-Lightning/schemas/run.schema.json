{
  "runDestinationFinal": {
    "type": "jobNameLocation",
    "label": "Job Name and Location",
    "help": "Optional. Leave blank to use defaults. If empty, the engine will assign a job ID and staging path automatically.",
    "customJobName": "",
    "pickerLabel": "Location",
    "showName": true,
    "showLocation": true,
    "disableJobNameChange": false,
    "disableJobLocationChange": false
  },

  "currentEnvDropdown": {
    "type": "dynamicSelect",
    "label": "Python Environment",
    "name": "currentEnvDropdown",
    "help": "Select a private virtual env with pytorch, lightning, and torchvision installed.",
    "retriever": "get_current_env.sh"
  },

  "ContainerDataset": {
    "type": "rowContainer",
    "label": "Dataset",
    "elements": {
      "datasetType": {
        "type": "radioGroup",
        "name": "datasetType",
        "label": "Dataset source",
        "options": [
          { "label": "Built-in (torchvision)", "value": "builtin" },
          { "label": "Custom directory", "value": "custom" }
        ],
        "value": "builtin"
      },
      "builtinDataset": {
        "type": "select",
        "label": "Built-in dataset",
        "name": "builtinDataset",
        "help": "Torchvision datasets are downloaded automatically on first use.",
        "condition": "datasetType.builtin",
        "options": [
          { "value": "MNIST", "label": "MNIST" },
          { "value": "FashionMNIST", "label": "Fashion-MNIST" },
          { "value": "CIFAR10", "label": "CIFAR-10" },
          { "value": "CIFAR100", "label": "CIFAR-100" }
        ],
        "value": "MNIST"
      },
      "customDataPath": {
        "type": "picker",
        "label": "Custom data directory",
        "name": "customDataPath",
        "remoteLabel": "local",
        "localLabel": "cluster",
        "showFiles": "False",
        "help": "Path to dataset root with train/ and val/ subdirectories (ImageFolder layout: class-named subfolders inside each split).",
        "condition": "datasetType.custom",
        "files": "False"
      }
    }
  },

  "ContainerHyperparams": {
    "type": "rowContainer",
    "label": "Training",
    "elements": {
      "epochs": {
        "type": "number",
        "label": "Epochs",
        "name": "epochs",
        "value": "10"
      },
      "batchSize": {
        "type": "number",
        "label": "Batch size",
        "name": "batchSize",
        "value": "32"
      },
      "learningRate": {
        "type": "text",
        "label": "Learning rate",
        "name": "learningRate",
        "value": "1e-3"
      },
      "numWorkers": {
        "type": "number",
        "label": "DataLoader workers",
        "name": "numWorkers",
        "value": "4"
      },
      "accelerator": {
        "type": "select",
        "label": "Accelerator",
        "name": "accelerator",
        "options": [
          { "value": "auto", "label": "Auto" },
          { "value": "cpu", "label": "CPU" },
          { "value": "gpu", "label": "GPU" }
        ],
        "value": "auto"
      }
    }
  },

  "ContainerLogging": {
    "type": "rowContainer",
    "label": "Logging",
    "elements": {
      "logDir": {
        "type": "text",
        "label": "Log directory",
        "name": "logDir",
        "value": "./lightning_logs"
      },
      "logEveryNSteps": {
        "type": "number",
        "label": "Log every N steps",
        "name": "logEveryNSteps",
        "value": "50"
      },
      "enableTensorBoard": {
        "type": "checkbox",
        "label": "Enable TensorBoard logger",
        "name": "enableTensorBoard",
        "value": "Yes"
      },
      "checkpointEnable": {
        "type": "checkbox",
        "label": "Enable model checkpointing",
        "name": "checkpointEnable",
        "value": "Yes"
      }
    }
  },

  "SlurmCheckbox": {
    "type": "checkbox",
    "label": "Set Job requirements",
    "name": "slurmbox",
    "help": "Check this box if you want to set Slurm options.",
    "value": "Yes"
  },

  "ContainerTasks": {
    "type": "rowContainer",
    "label": "GPU",
    "condition": "slurmbox.Yes)",
    "elements": {
      "cpus": {
        "type": "number",
        "label": "#CPUs/task",
        "name": "cpus",
        "value": "1",
        "max": "96"
      },
      "gpuDropdown": {
        "type": "dynamicSelect",
        "label": "Use Accelerator",
        "name": "gpu",
        "retriever": "retrieve_gpus"
      },
      "numgpus": {
        "type": "number",
        "label": "#GPUs",
        "name": "numgpu",
        "value": "1",
        "condition": " !gpu.none && !gpu. "
      }
    }
  },

  "ContainerAdditionals": {
    "type": "rowContainer",
    "label": "Slurm Options",
    "condition": "slurmbox.Yes",
    "elements": {
      "memory": {
        "type": "unit",
        "label": "Memory",
        "name": "memory",
        "units": [{ "label": "GB", "value": "G" }]
      },
      "Walltime": {
        "type": "time",
        "label": "Expected run time",
        "name": "walltime",
        "value": ""
      },
      "account": {
        "type": "dynamicSelect",
        "label": "Project Account",
        "name": "account",
        "retriever": "list_accounts"
      },
      "extraText": {
        "type": "text",
        "label": "Additional Slurm parameters",
        "name": "extra_slurm",
        "value": ""
      }
    }
  }
}
