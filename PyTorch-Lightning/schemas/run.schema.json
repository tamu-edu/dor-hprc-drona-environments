{
  "runDestinationFinal": {
    "type": "jobNameLocation",
    "label": "Job Name and Location",
    "help": "Optional. Leave blank to use defaults. If empty, the engine will assign a job ID and staging path automatically. Spaces in the job name are converted to underscores.",
    "customJobName": "",
    "pickerLabel": "Location",
    "showName": true,
    "showLocation": true,
    "disableJobNameChange": false,
    "disableJobLocationChange": false
  },

  "ContainerDataset": {
    "type": "rowContainer",
    "label": "Dataset",
    "elements": {
      "datasetType": {
        "type": "radioGroup",
        "name": "datasetType",
        "label": "Dataset source",
        "options": [
          { "label": "Built-in", "value": "builtin" },
          { "label": "Import", "value": "custom" }
        ],
        "value": "builtin"
      },
      "builtinDatasetRow": {
        "type": "rowContainer",
        "label": "",
        "condition": "datasetType.builtin",
        "elements": {
          "builtinDataset": {
            "type": "select",
            "label": "Built-in dataset",
            "name": "builtinDataset",
            "value": "MNIST",
            "help": "Datasets are downloaded automatically on the submit node when you click Submit (compute nodes have no internet).",
            "options": [
              { "value": "MNIST", "label": "MNIST" },
              { "value": "FashionMNIST", "label": "Fashion-MNIST" },
              { "value": "CIFAR10", "label": "CIFAR-10" },
              { "value": "CIFAR100", "label": "CIFAR-100" }
            ]
          }
        }
      },
      "customDataPath": {
        "type": "picker",
        "label": "Custom data directory",
        "name": "customDataPath",
        "remoteLabel": "local",
        "localLabel": "cluster",
        "showFiles": "False",
        "help": "Path to dataset root with train/ and val/ subdirectories. Each class is a subfolder containing .pt tensor files ([C,H,W] or dict with x/y keys).",
        "condition": "datasetType.custom",
        "files": "False"
      }
    }
  },

  "ContainerHyperparams": {
    "type": "rowContainer",
    "label": "Training",
    "elements": {
      "epochs": {
        "type": "number",
        "label": "Epochs",
        "name": "epochs",
        "value": "10"
      },
      "batchSize": {
        "type": "number",
        "label": "Batch size",
        "name": "batchSize",
        "value": "32"
      },
      "learningRate": {
        "type": "text",
        "label": "Learning rate",
        "name": "learningRate",
        "value": "1e-3",
        "placeholder": "e.g. 0.001 or 1e-3",
        "help": "Decimal or scientific notation only (e.g. 0.001, 1e-3). Invalid values are rejected when the job script is generated."
      },
      "numWorkers": {
        "type": "number",
        "label": "DataLoader workers",
        "name": "numWorkers",
        "value": "0",
        "help": "Number of DataLoader subprocesses. Use 0 on single-CPU allocations to avoid worker overhead."
      },
      "seed": {
        "type": "number",
        "label": "Random seed",
        "name": "seed",
        "value": "42",
        "help": "Seed for PyTorch Lightning and dataset randomness. Default is 42."
      }
    }
  },

  "ContainerLogging": {
    "type": "rowContainer",
    "label": "Logging",
    "elements": {
      "logDir": {
        "type": "picker",
        "label": "Log directory",
        "name": "logDir",
        "localLabel": "Location",
        "showFiles": "False",
        "files": "False",
        "defaultLocation": "./lightning_logs",
        "defaultPaths": {
          "HOME": "$HOME",
          "SCRATCH": "/scratch/user/$USER"
        },
        "useHPCDefaultPaths": "False",
        "help": "Directory where Lightning TensorBoard/CSV logs and checkpoints are written. Defaults to ./lightning_logs relative to the job staging directory."
      },
      "logEveryNSteps": {
        "type": "number",
        "label": "Log every N steps",
        "name": "logEveryNSteps",
        "value": "50"
      },
      "enableTensorBoard": {
        "type": "checkbox",
        "label": "Enable TensorBoard logger",
        "name": "enableTensorBoard",
        "value": "Yes"
      },
      "checkpointEnable": {
        "type": "checkbox",
        "label": "Enable model checkpointing",
        "name": "checkpointEnable",
        "value": "Yes"
      }
    }
  },

  "SlurmCheckbox": {
    "type": "checkbox",
    "label": "Set Job requirements",
    "name": "slurmbox",
    "help": "Check this box if you want to set Slurm options.",
    "value": "Yes"
  },

  "ContainerTasks": {
    "type": "rowContainer",
    "label": "GPU",
    "condition": "slurmbox.Yes",
    "elements": {
      "cpus": {
        "type": "number",
        "label": "#CPUs/task",
        "name": "cpus",
        "value": "1",
        "max": "96"
      },
      "gpuDropdown": {
        "type": "dynamicSelect",
        "label": "Use Accelerator",
        "name": "gpu",
        "value": "none",
        "help": "Optional. Defaults to CPU (no accelerator). Select a GPU only if your training will use it.",
        "retriever": "retrieve_gpus"
      },
      "numgpus": {
        "type": "number",
        "label": "#GPUs",
        "name": "numgpu",
        "value": "1",
        "condition": " !gpu.none && !gpu. "
      }
    }
  },

  "ContainerAdditionals": {
    "type": "rowContainer",
    "label": "Slurm Options",
    "condition": "slurmbox.Yes",
    "elements": {
      "memory": {
        "type": "unit",
        "label": "Memory",
        "name": "memory",
        "units": [{ "label": "GB", "value": "G" }]
      },
      "Walltime": {
        "type": "time",
        "label": "Expected run time",
        "name": "walltime",
        "value": ""
      },
      "account": {
        "type": "dynamicSelect",
        "label": "Project Account",
        "name": "account",
        "retriever": "list_accounts"
      },
      "extraText": {
        "type": "text",
        "label": "Additional Slurm parameters",
        "name": "extra_slurm",
        "value": ""
      }
    }
  }
}
