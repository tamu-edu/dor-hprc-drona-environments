{
  "monitor_help_banner": {
    "type": "rowContainer",
    "label": "",
    "condition": "mode.monitor",
    "elements": {
      "monitorHelp": {
        "type": "staticText",
        "label": "",
        "name": "monitor_help",
        "allowHtml": true,
        "value": "<div style='background:#e7f5ff;padding:10px 12px;border-radius:6px;font-size:0.95em;border-left:4px solid #339af0'><strong>Monitor mode</strong> — Select a training run below. The <strong>dashboard</strong> auto-refreshes every 15 seconds; use the single <strong>Refresh</strong> button (5 second cooldown) to update Slurm status and logs immediately. Click <strong>Preview</strong> for a snapshot tab. Submit does not launch a new training job.</div>"
      }
    }
  },

  "pt_location_link_row": {
    "type": "rowContainer",
    "label": "",
    "condition": "mode.monitor && !pt_workflow. && !pt_location.",
    "elements": {
      "pt_location_link": {
        "type": "staticText",
        "name": "pt_location_link_html",
        "isDynamic": true,
        "allowHtml": true,
        "retrieverParams": {
          "JOB_DIR": "$pt_location"
        },
        "retriever": "drona_info_jobdir_html.sh"
      }
    }
  },

  "pt_monitor_dashboard_row": {
    "type": "rowContainer",
    "label": "Dashboard",
    "condition": "mode.monitor && !pt_workflow. && !pt_location.",
    "elements": {
      "pt_monitor_dashboard": {
        "type": "staticText",
        "name": "pt_monitor_html",
        "isDynamic": true,
        "allowHtml": true,
        "refreshInterval": "15",
        "showRefreshButton": true,
        "retrieverParams": {
          "LOCATION": "$pt_location"
        },
        "retriever": "retrieve_pt_monitor_dashboard.sh"
      }
    }
  },

  "hidden_jobs_check": {
    "type": "hidden",
    "label": "JOB_IDS",
    "name": "jobs",
    "refreshInterval": "15",
    "isDynamic": true,
    "condition": "mode.monitor && !pt_workflow.",
    "retrieverParams": {
      "WORKFLOW_ID": "$pt_workflow"
    },
    "retriever": "drona_info_jobs.sh"
  },

  "hidden_status_check": {
    "type": "hidden",
    "name": "status",
    "label": "Status",
    "isDynamic": true,
    "condition": "mode.monitor && !jobs.",
    "refreshInterval": "15",
    "retrieverParams": {
      "JOBID": "$jobs"
    },
    "retriever": "drona_info_slurmstatus.sh"
  },

  "hidden_logdir": {
    "type": "hidden",
    "name": "resolved_logdir",
    "isDynamic": true,
    "condition": "mode.monitor && !pt_workflow.",
    "retrieverParams": {
      "WORKFLOW_ID": "$pt_workflow",
      "JOB_DIR": "$pt_location"
    },
    "retriever": "retrieve_pt_logdir.sh"
  },

  "job_summary_section": {
    "type": "rowContainer",
    "condition": "mode.monitor && !pt_workflow. && !status. && status.DONE && !jobs.",
    "label": "Job Summary",
    "elements": {
      "seff_summary": {
        "type": "staticText",
        "name": "seffsummary",
        "label": "Job Summary",
        "isDynamic": true,
        "retrieverParams": {
          "JOBIDS": "$jobs"
        },
        "retriever": "drona_slurm_seff.sh",
        "showRefreshButton": false,
        "allowHtml": true
      }
    }
  },

  "tbConnectToggle": {
    "type": "checkbox",
    "label": "Connect to TensorBoard server",
    "name": "tbConnectEnable",
    "help": "Optional. Enable to enter host and port for an already-running TensorBoard instance."
  },

  "tb_connect_section": {
    "type": "rowContainer",
    "label": "TensorBoard — Connect to Server",
    "condition": "tbConnectEnable.Yes",
    "elements": {
      "tbHost": {
        "type": "text",
        "label": "TensorBoard host",
        "name": "tbHost",
        "help": "Hostname or IP of a running TensorBoard server (e.g. compute node or localhost with port forwarding).",
        "value": "localhost"
      },
      "tbPort": {
        "type": "number",
        "label": "TensorBoard port",
        "name": "tbPort",
        "value": "6006"
      }
    }
  },

  "tb_launch_section": {
    "type": "rowContainer",
    "label": "TensorBoard — Launch from Run Logs",
    "condition": "mode.monitor && !pt_workflow.",
    "elements": {
      "tbLaunchStatus": {
        "type": "staticText",
        "name": "tb_launch_html",
        "label": "Launch instructions",
        "isDynamic": true,
        "allowHtml": true,
        "retrieverParams": {
          "RESOLVED_LOGDIR": "$resolved_logdir"
        },
        "retriever": "retrieve_tb_launch.sh"
      }
    }
  }
}
