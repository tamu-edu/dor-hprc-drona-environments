{
  "ModeRow": {
    "type": "rowContainer",
    "label": "",
    "elements": {
      "ModeRadio": {
        "type": "radioGroup",
        "name": "mode",
        "label": "Mode",
        "options": [
          { "label": "Run", "value": "run" },
          { "label": "Monitor", "value": "monitor" }
        ],
        "value": "run"
      }
    }
  },
  "pt_workflow_select": {
    "type": "dynamicSelect",
    "label": "Select Training Run",
    "name": "pt_workflow",
    "help": "Lists training runs submitted through this environment via Drona Composer (from the workflow database, not all Slurm jobs).",
    "condition": "mode.monitor",
    "retriever": "retrieve_pt_workflows.sh"
  },
  "RunContainer": {
    "type": "container",
    "elements": {
      "$ref": "schemas/run.schema.json"
    },
    "condition": "mode.run"
  },
  "MonitorContainer": {
    "type": "container",
    "elements": {
      "$ref": "schemas/monitor.schema.json"
    },
    "condition": "mode.monitor"
  }
}
