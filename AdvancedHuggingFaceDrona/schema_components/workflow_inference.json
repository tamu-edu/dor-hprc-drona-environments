        "allowHtml": true
      },
	  "modelContainer": {"$ref": "model.json#/modelContainer"},
      "modelSourceContainer": {"$ref": "model.json#/modelSourceContainer"},
      "modelSelectorContainer": {"$ref": "model.json#/modelSelectorContainer"},
      "modelDownloadedContainer": {"$ref": "model.json#/modelDownloadedContainer"},
      "modelInfoContainer": {"$ref": "model.json#/modelInfoContainer"},
      "datasetContainer": {"$ref": "dataset.json#/datasetContainer"},
