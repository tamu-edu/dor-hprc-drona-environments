{

   "configure" : {
    "type" : "hidden",
    "label" : "configured",
    "name" : "configured",
    "isDynamic": true,
    "retriever" : "drona_info_configure.sh"
  },

  "ManageCreateContainer" : {
    "type" : "rowContainer",
    "condition": "configured.CONFIGURED",
    "elements" : {

      "mode" : {
        "type": "radioGroup",
        "style": "button",
        "label": "Mode",
        "name": "mode",
        "condition": "configured.CONFIGURED",
        "options": [
          { "label": "Create", "value": "create" },
          { "label": "Manage", "value": "manage" }
        ]
      }

    }
  },



  "ConfigureContainer": {
    "type": "container",
    "elements": {
      "$ref": "schemas/configure.schema.json"
    },
    "condition": "configured.NOTCONFIGURED"
  },


  "CreateContainer": {
    "type": "container",
    "elements": {
      "$ref": "schemas/create.schema.json"
    },
    "condition": "mode.create"
  },

  "ManageContainer": {
    "type": "container",
    "elements": {
      "$ref": "schemas/manage.schema.json"
    },
    "condition": "mode.manage"
  }
}
